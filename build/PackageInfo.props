<Project>

	<PropertyGroup Label="Package Information">
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
		<PackageProjectUrl>https://github.com/cirreum/Cirreum.Identity.EntraExternalId</PackageProjectUrl>
		<RepositoryUrl>https://github.com/cirreum/Cirreum.Identity.EntraExternalId</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>cirreum;dotnet;blazor</PackageTags>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="/"/>
	</ItemGroup>

</Project>